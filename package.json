{
  "name": "standupbot-mcp",
  "version": "1.0.1",
  "description": "MCP server that summarizes your GitHub activity into a daily standup — commits, PRs, reviews, and issues in the last 24h.",
  "mcpName": "io.github.rimysore/standupbot",
  "main": "dist/index.js",
  "bin": {
    "standupbot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "github",
    "standup",
    "developer-tools",
    "claude",
    "model-context-protocol"
  ],
  "author": "rimysore03",
  "repository": {
    "type": "git",
    "url": "https://github.com/rimysore/standupbot-mcp.git"
  },
  "homepage": "https://github.com/rimysore/standupbot-mcp#readme",
  "bugs": {
    "url": "https://github.com/rimysore/standupbot-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
